# AI Scan Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# LLM Configuration (Required for AI summarization)
# ============================================
# Supports any OpenAI-compatible API endpoint

# Option 1: Alibaba Cloud DashScope (Qwen) - Default, cost-effective
# Get your key at: https://dashscope.console.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# Option 2: OpenAI
# LLM_API_KEY=sk-your_openai_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Option 3: DeepSeek (cost-effective alternative)
# LLM_API_KEY=your_deepseek_key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Option 4: Any other OpenAI-compatible endpoint
# LLM_API_KEY=your_key
# LLM_BASE_URL=https://your-endpoint.com/v1
# LLM_MODEL=your-model-name

# ============================================
# Optional: X/Twitter API
# ============================================
# Get your key at: https://developer.twitter.com/
X_API_BEARER_TOKEN=your_twitter_bearer_token_here
