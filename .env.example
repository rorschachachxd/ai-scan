# AI Scan Configuration
# Copy this file to .env and fill in your API keys

# Required: DashScope API Key for AI summarization
# Get your key at: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional: X/Twitter API Bearer Token for X/Twitter news
# Get your key at: https://developer.twitter.com/
X_API_BEARER_TOKEN=your_twitter_bearer_token_here
